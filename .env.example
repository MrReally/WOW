# --- API ---
PORT=4000
NODE_ENV=development

# PostgreSQL connection
DATABASE_URL=postgres://sever:sever@localhost:5432/sever

# Telegram Mini App auth.
# In development, AUTH_DEV_BYPASS=true lets the API accept a plain header
# (x-dev-user) instead of verified Telegram initData, so you can work in a
# normal browser. Set to false in production and provide TELEGRAM_BOT_TOKEN.
AUTH_DEV_BYPASS=true
TELEGRAM_BOT_TOKEN=

# --- WEB ---
# Base URL the frontend uses to reach the API.
VITE_API_URL=http://localhost:4000
